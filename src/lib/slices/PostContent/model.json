{
	"id": "postcontent",
	"type": "SharedSlice",
	"name": "PostContent",
	"description": "Displays individual post content (blog post or case study)",
	"variations": [
	  {
		"id": "default",
		"name": "Default",
		"docURL": "...",
		"version": "initial",
		"description": "Default variation",
		"primary": {
		  "title": {
			"type": "StructuredText",
			"config": {
			  "label": "Title",
			  "placeholder": "Enter the post title",
			  "allowTargetBlank": true,
			  "single": "heading1"
			}
		  },
		  "date": {
			"type": "Date",
			"config": {
			  "label": "Date",
			  "placeholder": "Select the post date"
			}
		  },
		  "author": {
			"type": "Text",
			"config": {
			  "label": "Author",
			  "placeholder": "Enter the author's name"
			}
		  },
		  "featured_image": {
			"type": "Image",
			"config": {
			  "label": "Featured Image",
			  "constraint": {},
			  "thumbnails": []
			}
		  },
		  "content": {
			"type": "StructuredText",
			"config": {
			  "label": "Content",
			  "placeholder": "Enter the post content",
			  "allowTargetBlank": true,
			  "multi": "paragraph,preformatted,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl"
			}
		  }
		},
		"items": {}
	  }
	]
  }