{
	"id": "postlist",
	"type": "SharedSlice",
	"name": "PostList",
	"description": "Displays a list of posts (blog posts or case studies)",
	"variations": [
	  {
		"id": "default",
		"name": "Default",
		"docURL": "...",
		"version": "initial",
		"description": "Default variation",
		"primary": {
		  "title": {
			"type": "StructuredText",
			"config": {
			  "label": "Title",
			  "placeholder": "Enter the section title",
			  "allowTargetBlank": true,
			  "single": "heading2"
			}
		  },
		  "description": {
			"type": "StructuredText",
			"config": {
			  "label": "Description",
			  "placeholder": "Enter a brief description",
			  "allowTargetBlank": true,
			  "multi": "paragraph,strong,em,hyperlink"
			}
		  }
		},
		"items": {
		  "post_title": {
			"type": "StructuredText",
			"config": {
			  "label": "Post Title",
			  "placeholder": "Enter the post title",
			  "allowTargetBlank": true,
			  "single": "heading3"
			}
		  },
		  "post_excerpt": {
			"type": "StructuredText",
			"config": {
			  "label": "Post Excerpt",
			  "placeholder": "Enter a brief excerpt",
			  "allowTargetBlank": true,
			  "multi": "paragraph,strong,em"
			}
		  },
		  "post_date": {
			"type": "Date",
			"config": {
			  "label": "Post Date",
			  "placeholder": "Select the post date"
			}
		  },
		  "post_image": {
			"type": "Image",
			"config": {
			  "label": "Post Image",
			  "constraint": {},
			  "thumbnails": []
			}
		  },
		  "post_link": {
			"type": "Link",
			"config": {
			  "label": "Post Link",
			  "placeholder": "Select the post link",
			  "allowTargetBlank": true
			}
		  }
		}
	  }
	]
  }