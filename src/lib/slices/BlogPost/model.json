  "name": "BlogPost",
  "description": "BlogPost",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "blog_title": {
          "type": "Text",
          "config": {
            "label": "Blog Title",
            "placeholder": "Enter the blog's title here"
