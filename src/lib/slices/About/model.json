{
  "id": "about",
  "type": "SharedSlice",
  "name": "About",
  "description": "About section for Kalvex",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default variation",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Enter the main title",
            "allowTargetBlank": true,
            "single": "heading1"
          }
        },
        "subtitle": {
          "type": "StructuredText",
          "config": {
            "label": "Subtitle",
            "placeholder": "Enter the subtitle",
            "allowTargetBlank": true,
            "single": "paragraph"
          }
        },
        "content": {
          "type": "StructuredText",
          "config": {
            "label": "Content",
            "placeholder": "Enter the main content",
            "allowTargetBlank": true,
            "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl"
          }
        },
        "logo": {
          "type": "Image",
          "config": {
            "label": "Logo",
            "constraint": {},
            "thumbnails": []
          }
        },
        "cta_title": {
          "type": "StructuredText",
          "config": {
            "label": "CTA Title",
            "placeholder": "Enter the CTA title",
            "allowTargetBlank": true,
            "single": "heading2"
          }
        },
        "cta_description": {
          "type": "StructuredText",
          "config": {
            "label": "CTA Description",
            "placeholder": "Enter the CTA description",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em,hyperlink"
          }
        },
        "cta_button_text": {
          "type": "Text",
          "config": {
            "label": "CTA Button Text",
            "placeholder": "Enter the CTA button text"
          }
        },
        "cta_button_link": {
          "type": "Link",
          "config": {
            "label": "CTA Button Link",
            "placeholder": "Enter the CTA button link",
            "allowTargetBlank": true
          }
        }
      },
      "items": {
        "employee_name": {
          "type": "Text",
          "config": {
            "label": "Employee Name",
            "placeholder": "Enter employee name"
          }
        },
        "employee_position": {
          "type": "Text",
          "config": {
            "label": "Employee Position",
            "placeholder": "Enter employee position"
          }
        },
        "employee_image": {
          "type": "Image",
          "config": {
            "label": "Employee Image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "employee_intro": {
          "type": "StructuredText",
          "config": {
            "label": "Employee Introduction",
            "placeholder": "Enter a brief introduction for the employee",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em,hyperlink"
          }
        }
      }
    }
  ]
}