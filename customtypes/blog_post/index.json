{
	"format": "custom",
	"id": "blog_post",
	"json": {
		"Main": {
			"uid": {
				"type": "UID",
				"config": {
					"label": "UID",
					"placeholder": "URL slug for the blog post"
				}
			},
			"title": {
				"type": "StructuredText",
				"config": {
					"single": "heading1",
					"label": "Title",
					"placeholder": "Blog post title"
				}
			},
			"date": {
				"type": "Date",
				"config": {
					"label": "Date",
					"placeholder": "Publication date"
				}
			},
			"author": {
				"type": "Text",
				"config": {
					"label": "Author",
					"placeholder": "Author name"
				}
			},
			"featured_image": {
				"type": "Image",
				"config": {
					"constraint": {},
					"thumbnails": [],
					"label": "Featured Image"
				}
			},
			"excerpt": {
				"type": "StructuredText",
				"config": {
					"multi": "paragraph",
					"label": "Excerpt",
					"placeholder": "Short excerpt for blog list view"
				}
			},
			"slices": {
				"type": "Slices",
				"fieldset": "Slice zone",
				"config": {
					"choices": {
						"postcontent": {
							"type": "SharedSlice"
						}
					}
				}
			}
		}
	},
	"label": "Blog Post",
	"repeatable": true,
	"status": true
}
