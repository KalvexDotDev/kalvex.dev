{
	"format": "custom",
	"id": "case_study",
	"json": {
		"Main": {
			"uid": {
				"type": "UID",
				"config": {
					"label": "UID",
					"placeholder": "URL slug for the case study"
				}
			},
			"title": {
				"type": "StructuredText",
				"config": {
					"single": "heading1",
					"label": "Title",
					"placeholder": "Case study title"
				}
			},
			"date": {
				"type": "Date",
				"config": {
					"label": "Date",
					"placeholder": "Publication date"
				}
			},
			"client": {
				"type": "Text",
				"config": {
					"label": "Client",
					"placeholder": "Client name"
				}
			},
			"featured_image": {
				"type": "Image",
				"config": {
					"constraint": {},
					"thumbnails": [],
					"label": "Featured Image"
				}
			},
			"excerpt": {
				"type": "StructuredText",
				"config": {
					"multi": "paragraph",
					"label": "Excerpt",
					"placeholder": "Short excerpt for case study list view"
				}
			},
			"slices": {
				"type": "Slices",
				"fieldset": "Slice zone",
				"config": {
					"choices": {
						"postcontent": {
							"type": "SharedSlice"
						}
					}
				}
			}
		}
	},
	"label": "Case Study",
	"repeatable": true,
	"status": true
}
